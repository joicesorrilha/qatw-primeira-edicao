pipeline {
    agent {
        docker {
            image 'joicesorrilha/playwright-nj-v1.61.0-noble'   // imagem docker que criei com node, java e playwright
            args '--network qatw-primeira-edicao_skynet'
        }
    }

    stages {
        stage('Node.js Deps') {
            steps {
                sh 'npm install'
            }
        }
        stage('Testes E2E') {
            steps {
                sh 'npx playwright test'
                allure commandline: 'allure', includeProperties: false, jdk: '', resultPolicy: 'LEAVE_AS_IS', results: [[path: 'allure-results']]
            }
        }
    }
}


